{
	"name": "bookstore-manager-cli",
	"version": "1.0.0",
	"description": "Aplicacao CLI para gerenciamento de uma livraria (autores, livros, clientes e emprestimos), utilizando Node.js, TypeScript e PostgreSQL.",
	"main": "dist/main.js",
	"scripts": {
		"dev": "tsx src/main.ts",
		"build": "tsc",
		"check": "tsc --noEmit",
		"start": "node dist/main.js"
	},
	"keywords": [
		"cli",
		"nodejs",
		"typescript",
		"postgresql"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"dotenv": "^16.4.5",
		"inquirer": "^8.2.6",
		"pg": "^8.12.0"
	},
	"devDependencies": {
		"@types/inquirer": "^8.2.10",
		"@types/node": "^22.5.0",
		"@types/pg": "^8.11.6",
		"tsx": "^4.19.0",
		"typescript": "^5.5.4"
	}
}
